<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_dark">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Price Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvStockName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apple Inc."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvExchange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NASDAQ • Technology"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="$195.00"
                            android:textColor="@color/green_400"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSignal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚀 STRONG BUY"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:chipBackgroundColor="@color/green_700" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+2.50 (+1.30%)"
                        android:textColor="@color/green_400"
                        android:textSize="16sp" />

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddPortfolio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+ Portfolio"
                            android:layout_marginEnd="6dp"
                            style="@style/ButtonGreen" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWatchlist"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="☆ Watchlist"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="@color/accent"
                            android:textColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetAlert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔔 Alert"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="@color/yellow_600"
                            android:textColor="@color/yellow_600" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Chart range chips -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip1D"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1D"
                            android:checked="true"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip1M"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1M"
                            style="@style/Widget.MaterialComponents.Chip.Filter" />
                    </com.google.android.material.chip.ChipGroup>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <ProgressBar
                            android:id="@+id/chartProgress"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:indeterminateTint="@color/accent" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Technical Analysis Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📊 Technical Analysis"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- Confidence bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvConfidence"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Confidence: 75%"
                            android:textColor="@color/accent"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvReturnPotential"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Return: +4.5%"
                            android:textColor="@color/green_400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressConfidence"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginBottom="12dp"
                        android:progressTint="@color/accent"
                        android:progress="75" />

                    <!-- Indicators Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3"
                        android:layout_marginBottom="10dp">

                        <TextView android:id="@+id/tvRSI" android:text="RSI: --"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />

                        <TextView android:id="@+id/tvMACD" android:text="MACD: --"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />

                        <TextView android:id="@+id/tvSMA20" android:text="SMA20: --"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />

                        <TextView android:id="@+id/tvSMA50" android:text="SMA50: --"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />

                        <TextView android:id="@+id/tvVolatility" android:text="Volatility: --"
                            android:textColor="@color/text_primary" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />

                        <TextView android:id="@+id/tvTargetPrice" android:text="Target: --"
                            android:textColor="@color/green_light" android:textSize="13sp"
                            android:layout_width="0dp" android:layout_columnWeight="1"
                            android:padding="4dp" />
                    </GridLayout>

                    <TextView android:id="@+id/tvStopLoss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stop Loss: --"
                        android:textColor="@color/red_400"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp" />

                    <!-- Signal Reasons -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Signal Reasons:"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvReasons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Loading analysis..."
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- P&L Calculator Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💰 P&amp;L Calculator"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Investment Amount ($)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etInvestAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary"
                            android:text="10000" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculatePL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calculate P&amp;L"
                        style="@style/ButtonGreen"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvProjectionAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Investment: $10,000"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvProjectionShares"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shares: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp" />

                    <!-- Projection rows -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="1 Day:" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/tvProj1D" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/green_400" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="7 Days:" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/tvProj7D" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/green_400" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="30 Days:" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/tvProj30D" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/green_400" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Key Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="📈 Key Statistics"
                        android:textColor="@color/text_primary" android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginBottom="10dp" />

                    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:columnCount="2" android:rowCount="5">

                        <!-- Stat Item helper macro (repeated pairs) -->
                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Open" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvOpen" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Day High" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvHigh" android:text="--" android:textColor="@color/green_400" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Day Low" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvLow" android:text="--" android:textColor="@color/red_400" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Volume" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvVolume" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Market Cap" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvMarketCap" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="P/E Ratio" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvPE" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="EPS" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvEPS" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="52W High" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tv52High" android:text="--" android:textColor="@color/green_400" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="52W Low" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tv52Low" android:text="--" android:textColor="@color/red_400" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Dividend" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvDividend" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1"
                            android:layout_height="wrap_content" android:orientation="vertical" android:padding="6dp">
                            <TextView android:text="Beta" android:textColor="@color/text_hint" android:textSize="11sp" />
                            <TextView android:id="@+id/tvBeta" android:text="--" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressDetail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/accent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
